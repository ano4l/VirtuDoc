# SQLite database path. Defaults to moneyfy.sqlite alongside server.js.
MONEYFY_DB=./moneyfy.sqlite
# Local file-store root for validated business logos. Use managed object storage
# before deploying multi-tenant production workloads.
MONEYFY_UPLOAD_DIR=./uploads
# Local HTTP port. Defaults to 4173.
PORT=4173
# Email is development-safe by default. "mock" records accepted_mock attempts only;
# it does not contact a provider or claim that a message was delivered.
MONEYFY_EMAIL_PROVIDER=mock
# Resend is supported when a verified sender and API key are configured. The generated
# PDF is attached and provider acceptance is recorded before the document becomes sent.
# Do not place production secrets in this local file.
# MONEYFY_EMAIL_PROVIDER=resend
# MONEYFY_RESEND_API_KEY=re_xxxxxxxxx
# MONEYFY_EMAIL_FROM="VirtuDoc <billing@example.com>"

# Supabase target stack. The app still defaults to local SQLite in development;
# use supabase/migrations to create the hosted Postgres schema before the
# durable adapter cutover.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=ey...
# SUPABASE_SERVICE_ROLE_KEY=ey...
# SUPABASE_DB_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# Future Railway cutover value for a persistent Node runtime and Postgres.
# DATABASE_URL=postgresql://user:password@host:port/database
