# Runtime
NODE_ENV=production
PORT=4173

# Vercel fallback storage. This is ephemeral on serverless functions and exists
# only so preview deployments can boot without external credentials.
MONEYFY_DB=/tmp/virtudoc.sqlite
MONEYFY_UPLOAD_DIR=/tmp/virtudoc-uploads

# Supabase project values. The SQL migration under supabase/migrations creates
# the target Postgres schema for the durable hosted database. Until the store is
# fully switched from SQLite to Postgres, keep production data on a persistent
# runtime such as Railway or use this Vercel deployment as a preview only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...
SUPABASE_DB_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# Resend transactional email. The application already sends PDF-backed messages
# with idempotency keys and records provider acceptance before marking sent.
MONEYFY_EMAIL_PROVIDER=resend
MONEYFY_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
MONEYFY_EMAIL_FROM="VirtuDoc <billing@yourdomain.com>"

# Future Railway cutover. Railway should receive the durable DATABASE_URL when
# the database adapter is switched from SQLite to Postgres.
DATABASE_URL=postgresql://user:password@host:port/database
